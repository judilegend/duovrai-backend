# ------------------------------------------------------------------------------
# DUOVRAI BACKEND CONFIGURATION
# Copy this file to .env and fill in the values before launching.
# ------------------------------------------------------------------------------

# Application Core Settings
ENVIRONMENT=development
PROJECT_NAME=Duovrai Backend
BACKEND_CORS_ORIGINS=["http://localhost:3000", "https://duovrai.com"]

# Database Configurations
# Use SQLite locally by default: sqlite:///./duovrai.db
# For PostgreSQL: postgresql+psycopg2://postgres:postgres@localhost:5432/duovrai
DATABASE_URL=sqlite:///./duovrai.db

# Stripe Integration
STRIPE_API_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/retry

# Stripe Product Price IDs (configured in Stripe Dashboard)
STRIPE_PRICE_ESSENTIEL=price_1...  # 9,90€
STRIPE_PRICE_PREMIUM=price_1...    # 19,90€

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Email Configurations (SMTP Server for Sending PDF Reports)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_...
SMTP_FROM_EMAIL=reports@duovrai.com
SMTP_FROM_NAME="Duovrai - Analyse Amoureuse"

# Storage Settings
PDF_OUTPUT_DIR=C:\Users\judi-legend\.gemini\antigravity\scratch\duovrai-backend\storage\reports
