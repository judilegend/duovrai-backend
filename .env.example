# --- Configuration de l'Application ---
ENV=development
APP_NAME="DUOVRAI | Par Indira — Astrologie IA"
DEBUG=True
VERSION=1.0.0

# --- Sécurité & CORS ---
SESSION_SECRET=your_super_secret_session_key_here
CORS_ORIGINS='["http://localhost:5173"]'

# --- Base de Données (PostgreSQL / Supabase) ---
DB_NAME=postgres
DB_PORT=6543
DB_HOST=your-database-host.supabase.com
DB_PASSWORD=your_secure_db_password
DB_USER=your_db_user

# --- Administration ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password

# --- Service d'Envoi d'Emails (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=no-reply@toncosmos.com
MAIL_FROM_NAME=TonCosmos
MAIL_STARTTLS=True
MAIL_SSL=False

# --- Configuration Stripe (Mode Test) ---
STRIPE_SECRET_KEY=sk_test_replace_with_your_own_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_own_secret

ANTHROPIC_API_KEY=sk-ant-replace_with_your_own_key